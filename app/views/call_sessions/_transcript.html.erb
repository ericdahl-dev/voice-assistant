<%
  turns = []
  if call_session.transcript.present?
    call_session.transcript.each_line do |line|
      line = line.chomp
      next if line.blank?
      if (m = line.match(/\A(Agent|Staff|User|Recipient):\s*(.*)/i))
        speaker = m[1].strip
        text    = m[2].strip
        role    = speaker.casecmp?("Agent") ? :agent : :recipient
      else
        speaker = nil
        text    = line
        role    = :unknown
      end
      turns << {speaker: speaker, text: text, role: role}
    end
  end
%>

<div id="call_session_transcript_<%= call_session.id %>" class="space-y-1">
  <% if turns.empty? %>
    <div class="flex flex-col items-center justify-center py-8 text-slate-400 dark:text-slate-500 gap-2">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
      </svg>
      <span class="text-sm">No transcript yet.</span>
    </div>
  <% else %>
    <% prev_role = nil %>
    <% turns.each do |turn| %>
      <% show_label = turn[:role] != prev_role %>
      <% prev_role = turn[:role] %>

      <% is_agent = turn[:role] == :agent %>
      <% is_unknown = turn[:role] == :unknown %>
      <% label = if is_agent
        "Agent"
      elsif turn[:speaker]
        turn[:speaker]
      elsif is_unknown
        "System"
      else
        "Other"
      end %>
      <% row_classes = is_agent ? "justify-end" : "justify-start" %>
      <% bubble_classes = if is_agent
        "bg-indigo-600 text-white dark:bg-indigo-500"
      elsif is_unknown
        "bg-slate-100 text-slate-700 dark:bg-slate-700/60 dark:text-slate-200"
      else
        "bg-slate-100 text-slate-800 dark:bg-slate-700 dark:text-slate-100"
      end %>

      <div class="flex <%= row_classes %> <%= show_label ? "mt-3" : "mt-1" %>">
        <div class="max-w-[85%] sm:max-w-[75%]">
          <% if show_label %>
            <span class="transcript-speaker-label block mb-1 text-xs font-semibold uppercase tracking-widest font-mono <%= is_agent ? "text-indigo-600 dark:text-indigo-400 text-right" : "text-slate-500 dark:text-slate-400" %>"><%= label %></span>
          <% end %>
          <div class="rounded-2xl px-3 py-2 shadow-sm <%= bubble_classes %>">
            <p class="text-sm leading-snug break-words"><%= turn[:text] %></p>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
