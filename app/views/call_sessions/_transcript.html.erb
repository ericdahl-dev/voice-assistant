<%
  turns = []
  if call_session.transcript.present?
    call_session.transcript.each_line do |line|
      line = line.chomp
      next if line.blank?
      if (m = line.match(/\A(Agent|Staff|User|Recipient):\s*(.*)/i))
        speaker = m[1].strip
        text    = m[2].strip
        role    = speaker.casecmp?("Agent") ? :agent : :recipient
      else
        speaker = nil
        text    = line
        role    = :unknown
      end
      turns << {speaker: speaker, text: text, role: role}
    end
  end
%>

<div id="call_session_transcript_<%= call_session.id %>" class="space-y-1">
  <% if turns.empty? %>
    <div class="flex flex-col items-center justify-center py-8 text-slate-400 dark:text-slate-500 gap-2">
      <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M8.625 12a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H8.25m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0H12m4.125 0a.375.375 0 11-.75 0 .375.375 0 01.75 0zm0 0h-.375M21 12c0 4.556-4.03 8.25-9 8.25a9.764 9.764 0 01-2.555-.337A5.972 5.972 0 015.41 20.97a5.969 5.969 0 01-.474-.065 4.48 4.48 0 00.978-2.025c.09-.457-.133-.901-.467-1.226C3.93 16.178 3 14.189 3 12c0-4.556 4.03-8.25 9-8.25s9 3.694 9 8.25z" />
      </svg>
      <span class="text-sm">No transcript yet.</span>
    </div>
  <% else %>
    <% prev_role = nil %>
    <% turns.each do |turn| %>
      <% show_label = turn[:role] != prev_role %>
      <% prev_role = turn[:role] %>

      <% if turn[:role] == :agent %>
        <div class="flex gap-2 items-start <%= show_label ? "mt-3" : "mt-0.5" %>">
          <% if show_label %>
            <div class="shrink-0 w-6 h-6 rounded-full bg-indigo-100 dark:bg-indigo-900/50 flex items-center justify-center mt-0.5">
              <svg class="w-3.5 h-3.5 text-indigo-600 dark:text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09z" />
              </svg>
            </div>
          <% else %>
            <div class="shrink-0 w-6"></div>
          <% end %>
          <div class="flex-1 min-w-0">
            <% if show_label %>
              <span class="block text-xs font-semibold uppercase tracking-widest text-indigo-600 dark:text-indigo-400 font-mono mb-0.5">Agent</span>
            <% end %>
            <p class="text-sm font-medium text-slate-800 dark:text-slate-200 leading-snug"><%= turn[:text] %></p>
          </div>
        </div>
      <% else %>
        <div class="flex gap-2 items-start <%= show_label ? "mt-3" : "mt-0.5" %>">
          <% if show_label %>
            <div class="shrink-0 w-6 h-6 rounded-full bg-slate-100 dark:bg-slate-700 flex items-center justify-center mt-0.5">
              <svg class="w-3.5 h-3.5 text-slate-500 dark:text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z" />
              </svg>
            </div>
          <% else %>
            <div class="shrink-0 w-6"></div>
          <% end %>
          <div class="flex-1 min-w-0">
            <% if show_label %>
              <span class="block text-xs font-semibold uppercase tracking-widest text-slate-500 dark:text-slate-400 font-mono mb-0.5"><%= turn[:speaker] || "Other" %></span>
            <% end %>
            <p class="text-sm text-slate-700 dark:text-slate-300 leading-snug"><%= turn[:text] %></p>
          </div>
        </div>
      <% end %>
    <% end %>
  <% end %>
</div>
