<%# Rendered as a Turbo Stream target whenever CallSession#broadcast_status_update fires. %>
<div id="<%= dom_id(call_session) %>" class="flex items-center justify-between gap-4 py-3">
  <div class="flex items-center gap-3 min-w-0">
    <div class="w-7 h-7 rounded-full bg-slate-100 dark:bg-slate-800 flex items-center justify-center shrink-0">
      <svg class="w-3.5 h-3.5 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
      </svg>
    </div>
    <div class="min-w-0">
      <p class="text-xs text-slate-500">Session <%= call_session.id %></p>
    </div>
  </div>

  <div class="flex items-center gap-3 shrink-0 text-xs text-slate-500">
    <%
      badge = case call_session.status
        when "completed"    then "badge-green"
        when "connected", "in_conversation" then "badge-blue"
        when "dialing", "queued" then "badge-amber"
        when "failed"       then "badge-red"
        when "needs_user"   then "badge-purple"
        else "badge-slate"
      end
    %>
    <span class="<%= badge %>"><%= call_session.status.humanize %></span>
    <% if call_session.started_at %>
      <span>Started <%= call_session.started_at.strftime("%l:%M %p") %></span>
    <% end %>
    <% if call_session.ended_at %>
      <span>&mdash; Ended <%= call_session.ended_at.strftime("%l:%M %p") %></span>
    <% end %>
  </div>
</div>
