<%# Issue #9 / #12: Real-time CallSession status UI + Outcome display %>
<% content_for :title, "Call Session ##{@call_session.id}" %>

<div class="max-w-2xl mx-auto py-8 px-4">
  <%= turbo_stream_from [@delegation, :call_sessions] %>

  <div class="mb-6">
    <%= link_to "← Back to Delegation", delegation_path(@delegation), class: "text-sm text-slate-500 hover:text-slate-700 dark:hover:text-slate-300" %>
  </div>

  <h1 class="text-2xl font-semibold text-slate-900 dark:text-white mb-6">
    Call to <%= @call_session.call_plan.target_name %>
  </h1>

  <%# Declined banner %>
  <% if @call_session.completed? && @call_session.outcome&.dig("status") == "declined" %>
    <div class="mb-6 rounded-lg border border-slate-300 bg-slate-50 dark:bg-slate-800/50 dark:border-slate-600 p-4 flex gap-3 items-start">
      <svg class="w-5 h-5 text-slate-500 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" />
      </svg>
      <div>
        <p class="font-medium text-slate-700 dark:text-slate-300">Business declined AI call</p>
        <p class="text-sm text-slate-500 dark:text-slate-400 mt-1">The business chose not to continue after hearing the AI disclosure. Consider calling manually.</p>
      </div>
    </div>
  <% end %>

  <%# Escalation banner — only shown when needs_user %>
  <% if @call_session.needs_user? %>
    <div class="mb-6 rounded-lg border border-amber-300 bg-amber-50 dark:bg-amber-900/20 dark:border-amber-700 p-4 flex gap-3 items-start">
      <svg class="w-5 h-5 text-amber-600 dark:text-amber-400 shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m-9.303 3.376c-.866 1.5.217 3.374 1.948 3.374h14.71c1.73 0 2.813-1.874 1.948-3.374L13.949 3.378c-.866-1.5-3.032-1.5-3.898 0L2.697 16.126zM12 15.75h.007v.008H12v-.008z" />
      </svg>
      <div>
        <p class="font-medium text-amber-800 dark:text-amber-300">Your attention is needed</p>
        <p class="text-sm text-amber-700 dark:text-amber-400 mt-1">The AI has encountered a situation that requires your input before continuing.</p>
      </div>
    </div>
  <% end %>

  <%# Status card with Turbo Stream target %>
  <div class="rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800 p-5 mb-6">
    <%= render "call_sessions/call_session", call_session: @call_session %>
  </div>

  <%# Outcome card — Turbo Stream target: call_session_outcome_ID %>
  <%= render "call_sessions/outcome", call_session: @call_session %>

  <%# Collapsible transcript %>
  <details class="rounded-lg border border-slate-200 dark:border-slate-700 bg-white dark:bg-slate-800">
    <summary class="flex items-center justify-between px-5 py-4 cursor-pointer select-none text-sm font-medium text-slate-600 dark:text-slate-400 uppercase tracking-wide list-none">
      Transcript
      <svg class="w-4 h-4 transition-transform duration-200 [[open]_&]:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </summary>
    <div class="px-5 pb-5 border-t border-slate-100 dark:border-slate-700 pt-4">
      <div id="call_session_transcript_<%= @call_session.id %>" class="text-sm text-slate-700 dark:text-slate-300 whitespace-pre-wrap leading-relaxed min-h-[4rem]">
        <%= @call_session.transcript.presence || content_tag(:span, "No transcript yet.", class: "text-slate-400 italic") %>
      </div>
    </div>
  </details>
</div>
