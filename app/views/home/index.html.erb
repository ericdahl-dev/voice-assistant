<div class="flex flex-col gap-8">
  <%# Hero greeting %>
  <div class="card overflow-hidden">
    <div class="bg-gradient-to-r from-brand-600 to-brand-700 px-6 py-8">
      <p class="text-brand-200 text-sm font-medium mb-1">Welcome back</p>
      <h1 class="text-2xl font-semibold text-white" style="font-family: var(--font-display)">
        Your AI calling assistant is ready.
      </h1>
      <p class="text-brand-100/80 text-sm mt-2 max-w-md">
        Delegate annoying life-admin calls to an AI agent. It calls, it talks, it reports back.
      </p>
    </div>
    <div class="card-footer flex items-center justify-between gap-4">
      <%= link_to delegations_path, class: "btn-primary btn-lg" do %>
        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
        </svg>
        New delegation
      <% end %>
      <span class="text-xs text-slate-500 hidden sm:block">AI handles the call &mdash; you stay updated in real time</span>
    </div>
  </div>

  <%# How it works %>
  <div>
    <p class="section-title">How it works</p>
    <div class="grid sm:grid-cols-3 gap-4">
      <% [
        { icon: "📋", step: "1", title: "Create a Call Plan", body: "Tell the AI who to call, what to say, and what information to share." },
        { icon: "✅", step: "2", title: "Review & Approve", body: "Check the plan, then approve it. The AI won't dial until you say go." },
        { icon: "📞", step: "3", title: "Get the Outcome", body: "The AI calls, completes the task, and reports back with a full summary." }
      ].each do |item| %>
        <div class="card card-body flex flex-col gap-3">
          <div class="w-8 h-8 rounded-full bg-brand-50 text-brand-700 text-sm font-semibold flex items-center justify-center border border-brand-100">
            <%= item[:step] %>
          </div>
          <div>
            <p class="text-sm font-semibold text-slate-900 dark:text-slate-100"><%= item[:title] %></p>
            <p class="text-xs text-slate-500 dark:text-slate-400 mt-0.5 leading-relaxed"><%= item[:body] %></p>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
