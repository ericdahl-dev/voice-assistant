<%# Landing page — public, no auth required %>
<div class="min-h-screen bg-white dark:bg-slate-950 flex flex-col">

  <%# ── Nav ── %>
  <nav class="sticky top-0 z-30 bg-white/80 dark:bg-slate-950/80 backdrop-blur border-b border-slate-100 dark:border-slate-900">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 h-14 flex items-center justify-between gap-4">
      <a href="/" class="flex items-center gap-2 shrink-0">
        <div class="w-7 h-7 rounded-lg bg-brand-600 flex items-center justify-center shadow-sm">
          <svg class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
          </svg>
        </div>
        <span class="font-semibold text-slate-900 dark:text-slate-100 text-sm tracking-tight" style="font-family: var(--font-display)">Callspark</span>
      </a>
      <div class="flex items-center gap-3">
        <button data-action="theme#toggle"
                class="btn-ghost p-2 rounded-lg"
                aria-label="Toggle dark mode">
          <svg class="w-4 h-4 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0z"/>
          </svg>
          <svg class="w-4 h-4 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998z"/>
          </svg>
        </button>
        <%= link_to "Log in", new_user_session_path, class: "btn-ghost text-sm" %>
        <%= link_to "Get started", new_user_registration_path, class: "btn-primary text-sm" %>
      </div>
    </div>
  </nav>

  <%# ── Hero ── %>
  <section class="relative overflow-hidden">
    <%# Background glow %>
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 left-1/2 -translate-x-1/2 w-[900px] h-[500px] bg-brand-500/10 dark:bg-brand-500/5 rounded-full blur-3xl"></div>
    </div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 pt-24 pb-20 text-center">
      <div class="inline-flex items-center gap-2 rounded-full bg-brand-50 dark:bg-brand-950 text-brand-700 dark:text-brand-300 text-xs font-medium px-3 py-1.5 border border-brand-100 dark:border-brand-900 mb-8">
        <span class="w-1.5 h-1.5 rounded-full bg-brand-500 animate-pulse"></span>
        AI places the call. You get the outcome.
      </div>

      <h1 class="text-5xl sm:text-6xl font-bold text-slate-900 dark:text-white leading-tight tracking-tight mb-6" style="font-family: var(--font-display)">
        Stop dreading<br class="hidden sm:block">
        <span class="text-brand-600 dark:text-brand-400">annoying phone calls.</span>
      </h1>

      <p class="text-xl text-slate-600 dark:text-slate-400 max-w-2xl mx-auto mb-10 leading-relaxed">
        Callspark delegates your life-admin calls to an AI agent. Tell it what to say, who to call, and what to find out — it handles the rest and reports back.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <%= link_to "Start delegating for free", new_user_registration_path, class: "btn-primary btn-lg shadow-lg shadow-brand-500/25" %>
        <a href="#how-it-works" class="btn-secondary btn-lg">
          See how it works
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5"/>
          </svg>
        </a>
      </div>

      <%# Social proof %>
      <p class="mt-10 text-xs text-slate-400 dark:text-slate-600">No credit card required &middot; Calls start in seconds</p>
    </div>
  </section>

  <%# ── Use cases strip ── %>
  <section class="border-y border-slate-100 dark:border-slate-900 bg-slate-50 dark:bg-slate-900/50 py-5">
    <div class="max-w-5xl mx-auto px-4 sm:px-6">
      <p class="text-xs text-slate-400 dark:text-slate-600 font-medium text-center uppercase tracking-widest mb-4">Perfect for</p>
      <div class="flex flex-wrap justify-center gap-x-8 gap-y-3">
        <% [
          "🚗 Auto repair status checks",
          "💊 Prescription refills",
          "📅 Appointment scheduling",
          "🏥 Doctor office follow-ups",
          "📦 Delivery & order inquiries",
          "🏢 Business hours & availability"
        ].each do |item| %>
          <span class="text-sm text-slate-600 dark:text-slate-400"><%= item %></span>
        <% end %>
      </div>
    </div>
  </section>

  <%# ── Features ── %>
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-24">
    <div class="text-center mb-16">
      <p class="section-title">Why Callspark</p>
      <h2 class="text-3xl font-bold text-slate-900 dark:text-white tracking-tight" style="font-family: var(--font-display)">
        Your AI calling agent.<br>You're always in control.
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8">
      <% [
        {
          icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/>',
          title: "You approve every call",
          body: "Review the full call plan before anything dials. The AI never acts without your sign-off."
        },
        {
          icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/>',
          title: "Real-time escalation",
          body: "If the AI hits a question it can't answer alone, it pauses the call and pings you for a decision."
        },
        {
          icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z"/>',
          title: "Full transcript & outcome",
          body: "Every call session delivers a structured outcome — summary, key details, follow-up needed."
        },
        {
          icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 013 3m3 0a6 6 0 01-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1121.75 8.25z"/>',
          title: "Guardrails you set",
          body: "Define exactly what the AI can share, what to ask, and what it must never do. Enforced every call."
        },
        {
          icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>',
          title: "Transparent disclosure",
          body: "The AI always identifies itself as AI and names you. Ethical, compliant, and honest from the first word."
        },
        {
          icon: '<path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 9v7.5"/>',
          title: "Call templates",
          body: "Start from curated templates for common tasks. Fill in the blanks, approve, done."
        }
      ].each do |feat| %>
        <div class="flex gap-4">
          <div class="w-10 h-10 rounded-xl bg-brand-50 dark:bg-brand-950 border border-brand-100 dark:border-brand-900 flex items-center justify-center shrink-0">
            <svg class="w-5 h-5 text-brand-600 dark:text-brand-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
              <%= feat[:icon].html_safe %>
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-slate-900 dark:text-slate-100 mb-1"><%= feat[:title] %></p>
            <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed"><%= feat[:body] %></p>
          </div>
        </div>
      <% end %>
    </div>
  </section>

  <%# ── How it works ── %>
  <section id="how-it-works" class="bg-slate-50 dark:bg-slate-900/50 border-y border-slate-100 dark:border-slate-900 py-24">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-16">
        <p class="section-title">How it works</p>
        <h2 class="text-3xl font-bold text-slate-900 dark:text-white tracking-tight" style="font-family: var(--font-display)">
          From idea to outcome in minutes.
        </h2>
      </div>

      <div class="relative">
        <%# Connecting line — desktop only %>
        <div class="hidden lg:block absolute top-8 left-16 right-16 h-px bg-gradient-to-r from-brand-200 via-brand-400 to-brand-200 dark:from-brand-900 dark:via-brand-700 dark:to-brand-900"></div>

        <div class="grid lg:grid-cols-4 gap-10">
          <% [
            { n: "1", title: "Choose a template",    body: "Pick a call type or start from scratch." },
            { n: "2", title: "Set the details",      body: "Who to call, what to say, what to find out." },
            { n: "3", title: "Review & approve",     body: "Check the plan. Hit approve when ready." },
            { n: "4", title: "Get the outcome",      body: "AI calls, talks, and reports back to you." }
          ].each do |step| %>
            <div class="flex flex-col items-center text-center gap-3">
              <div class="relative w-16 h-16 rounded-2xl bg-white dark:bg-slate-900 border-2 border-brand-200 dark:border-brand-800 flex items-center justify-center shadow-sm z-10">
                <span class="text-2xl font-bold text-brand-600 dark:text-brand-400" style="font-family: var(--font-display)"><%= step[:n] %></span>
              </div>
              <p class="text-sm font-semibold text-slate-900 dark:text-slate-100"><%= step[:title] %></p>
              <p class="text-xs text-slate-500 dark:text-slate-400 leading-relaxed"><%= step[:body] %></p>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </section>

  <%# ── CTA ── %>
  <section class="max-w-2xl mx-auto px-4 sm:px-6 py-24 text-center">
    <h2 class="text-3xl font-bold text-slate-900 dark:text-white mb-4 tracking-tight" style="font-family: var(--font-display)">
      Ready to stop avoiding your phone?
    </h2>
    <p class="text-slate-500 dark:text-slate-400 mb-8 leading-relaxed">
      Join the people delegating tedious calls to Callspark. Free to start — no credit card needed.
    </p>
    <%= link_to "Create your free account", new_user_registration_path, class: "btn-primary btn-lg shadow-lg shadow-brand-500/25" %>
  </section>

  <%# ── Footer ── %>
  <footer class="border-t border-slate-100 dark:border-slate-900 py-8 mt-auto">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <div class="flex items-center gap-2">
        <div class="w-5 h-5 rounded bg-brand-600 flex items-center justify-center">
          <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
          </svg>
        </div>
        <span class="text-xs font-semibold text-slate-700 dark:text-slate-300" style="font-family: var(--font-display)">Callspark</span>
      </div>
      <p class="text-xs text-slate-400 dark:text-slate-600">&copy; <%= Time.current.year %> Callspark. AI-powered outbound calling.</p>
    </div>
  </footer>

</div>
