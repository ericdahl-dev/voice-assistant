<div class="auth-wrapper">
  <div class="auth-card">
    <div class="bg-gradient-to-r from-brand-600 to-brand-700 rounded-t-xl px-8 py-7 text-center">
      <h1 class="text-xl font-semibold text-white" style="font-family: var(--font-display)">Reset your password</h1>
      <p class="text-brand-200/80 text-sm mt-1">We'll send you reset instructions</p>
    </div>

    <div class="card-body">
      <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-4" }) do |f| %>
        <%= render "devise/shared/error_messages", resource: resource %>

        <div class="form-field">
          <%= f.label :email, class: "form-label" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input" %>
        </div>

        <div class="pt-1">
          <%= f.submit "Send reset instructions", class: "btn-primary w-full justify-center py-2.5 text-base cursor-pointer" %>
        </div>
      <% end %>
    </div>

    <div class="card-footer text-center space-y-2">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
