<div class="auth-wrapper">
  <div class="auth-card">
    <%# Brand header %>
    <div class="bg-gradient-to-r from-brand-600 to-brand-700 rounded-t-xl px-8 py-7 text-center">
      <div class="w-10 h-10 rounded-xl bg-white/20 flex items-center justify-center mx-auto mb-3 shadow-sm">
        <svg class="w-5 h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 6.75c0 8.284 6.716 15 15 15h2.25a2.25 2.25 0 002.25-2.25v-1.372c0-.516-.351-.966-.852-1.091l-4.423-1.106c-.44-.11-.902.055-1.173.417l-.97 1.293c-.282.376-.769.542-1.21.38a12.035 12.035 0 01-7.143-7.143c-.162-.441.004-.928.38-1.21l1.293-.97c.363-.271.527-.734.417-1.173L6.963 3.102a1.125 1.125 0 00-1.091-.852H4.5A2.25 2.25 0 002.25 4.5v2.25z"/>
        </svg>
      </div>
      <h1 class="text-xl font-semibold text-white" style="font-family: var(--font-display)">Welcome back</h1>
      <p class="text-brand-200/80 text-sm mt-1">Sign in to your Callspark account</p>
    </div>

    <div class="card-body">
      <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "space-y-4" }) do |f| %>
        <div class="form-field">
          <%= f.label :email, class: "form-label" %>
          <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input" %>
        </div>

        <div class="form-field">
          <%= f.label :password, class: "form-label" %>
          <%= f.password_field :password, autocomplete: "current-password", class: "form-input" %>
        </div>

        <% if devise_mapping.rememberable? %>
          <div class="flex items-center gap-2">
            <%= f.check_box :remember_me, class: "w-4 h-4 rounded border-slate-300 text-brand-600 focus:ring-brand-500" %>
            <%= f.label :remember_me, class: "text-sm text-slate-600 dark:text-slate-300 cursor-pointer select-none" %>
          </div>
        <% end %>

        <div class="pt-1">
          <%= f.submit "Sign in", class: "btn-primary w-full justify-center py-2.5 text-base cursor-pointer" %>
        </div>
      <% end %>
    </div>

    <div class="card-footer text-center space-y-2">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>
