<div class="max-w-2xl">
  <div class="page-header">
    <div>
      <h1 class="page-title">Edit call plan</h1>
      <p class="page-subtitle">Make changes before approving.</p>
    </div>
  </div>

  <%= form_with model: [@delegation, @call_plan], url: delegation_call_plan_path(@delegation), method: :patch, class: "space-y-6" do |f| %>
    <%= render "call_plans/form_fields", f: f, call_plan: @call_plan %>

    <div class="flex items-center gap-3 pt-2">
      <%= f.submit "Save changes", class: "btn-primary btn-lg cursor-pointer" %>
      <%= link_to "Cancel", delegation_call_plan_path(@delegation), class: "btn-secondary btn-lg" %>
    </div>
  <% end %>
</div>
