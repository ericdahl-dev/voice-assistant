<%# The auto repair template seeds goal_template as a plain string (no interpolation needed in Phase 1). %>
<%# We render it as-is here and let the agent use it verbatim. %>

<div class="max-w-2xl">
  <div class="page-header">
    <div>
      <h1 class="page-title">Create your call plan</h1>
      <% if @template %>
        <p class="page-subtitle">Using template: <strong class="text-slate-700 dark:text-slate-300"><%= @template.name %></strong></p>
        <% if @template.description.present? %>
          <p class="text-xs text-slate-500 mt-1"><%= @template.description %></p>
        <% end %>
      <% else %>
        <p class="page-subtitle">Fill in the details and the AI will handle the rest.</p>
      <% end %>
    </div>
  </div>

  <%= form_with model: [@delegation, @call_plan], class: "space-y-6" do |f| %>
    <%= render "call_plans/form_fields", f: f, call_plan: @call_plan %>

    <div class="flex items-center gap-3 pt-2">
      <%= f.submit "Save call plan", class: "btn-primary btn-lg cursor-pointer" %>
      <%= link_to "Cancel", delegations_path, class: "btn-secondary btn-lg" %>
    </div>
  <% end %>
</div>
